[tasks]
basic bmc
cover_task1 cover
prove_task1 prove


[options]
bmc: 
mode bmc
depth 30
cover:
mode cover
depth 30
prove:
mode prove
--

[engines]
smtbmc boolector

[script]
read -formal uart_core.v
read -sv fifo.v
read -sv uart_tx.v
read -sv pulse_generator.v
read -sv uart_rx.v
hierarchy -check -top uart_core
prep -top uart_core

[files]
uart_core.v
pulse_generator.v
uart_rx.v
uart_tx.v
fifo.v