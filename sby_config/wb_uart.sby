[tasks]
basic bmc
cover_task1 cover
prove_task1 prove


[options]
bmc: 
mode bmc
depth 30
cover:
mode cover
depth 30
prove:
mode prove
--

[engines]
smtbmc boolector

[script]
read -formal wb_uart.v
read -sv uart_regfile.v
read -sv fifo.v
read -sv uart_tx.v
read -sv pulse_generator.v
read -sv uart_rx.v
hierarchy -check -top wb_uart
prep -top wb_uart

[files]
wb_uart.v
pulse_generator.v
uart_rx.v
uart_tx.v
uart_regfile.v
fifo.v